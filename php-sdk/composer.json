{
    "name": "ag-ui/php-sdk",
    "description": "PHP SDK for AG-UI - Event-based protocol for agent-user interactions",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "packages/core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/proto",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/client",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/encoder",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "packages/cli",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "integrations/laravel",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "integrations/symfony",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.1",
        "ag-ui/core": "*",
        "ag-ui/proto": "*",
        "ag-ui/client": "*",
        "ag-ui/encoder": "*",
        "ag-ui/cli": "*",
        "ag-ui/laravel-integration": "*",
        "ag-ui/symfony-integration": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.0",
        "phpstan/phpstan": "^1.0",
        "psalm/phar": "^5.0"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "lint": "phpcs --standard=PSR12 packages/*/src/",
        "lint-fix": "phpcbf --standard=PSR12 packages/*/src/",
        "analyze": "phpstan analyse packages/*/src/",
        "psalm": "psalm",
        "build": [
            "@composer install --no-dev --optimize-autoloader",
            "composer build-all"
        ],
        "build-all": [
            "cd packages/core && composer install --no-dev --optimize-autoloader",
            "cd packages/proto && composer install --no-dev --optimize-autoloader",
            "cd packages/client && composer install --no-dev --optimize-autoloader",
            "cd packages/encoder && composer install --no-dev --optimize-autoloader",
            "cd packages/cli && composer install --no-dev --optimize-autoloader",
            "cd integrations/laravel && composer install --no-dev --optimize-autoloader",
            "cd integrations/symfony && composer install --no-dev --optimize-autoloader"
        ],
        "test-all": [
            "cd packages/core && composer test",
            "cd packages/proto && composer test",
            "cd packages/client && composer test",
            "cd packages/encoder && composer test",
            "cd packages/cli && composer test",
            "cd integrations/laravel && composer test",
            "cd integrations/symfony && composer test"
        ],
        "clean": "rm -rf vendor/ coverage/ packages/*/vendor/ integrations/*/vendor/",
        "post-install-cmd": [
            "composer install-working-dir packages/core",
            "composer install-working-dir packages/proto",
            "composer install-working-dir packages/client",
            "composer install-working-dir packages/encoder",
            "composer install-working-dir packages/cli",
            "composer install-working-dir integrations/laravel",
            "composer install-working-dir integrations/symfony"
        ],
        "post-update-cmd": [
            "composer install-working-dir packages/core",
            "composer install-working-dir packages/proto",
            "composer install-working-dir packages/client",
            "composer install-working-dir packages/encoder",
            "composer install-working-dir packages/cli",
            "composer install-working-dir integrations/laravel",
            "composer install-working-dir integrations/symfony"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "authors": [
        {
            "name": "AG-UI Team",
            "email": "team@ag-ui.org"
        }
    ],
    "keywords": [
        "ag-ui",
        "agent-ui",
        "event-driven",
        "protocol",
        "ai",
        "agent"
    ],
    "support": {
        "issues": "https://github.com/ag-ui/ag-ui/issues",
        "source": "https://github.com/ag-ui/ag-ui"
    }
}