{
    "name": "ag-ui/php-sdk",
    "description": "PHP SDK for AG-UI - Event-based protocol for agent-user interactions",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0",
        "guzzlehttp/guzzle": "^7.0",
        "monolog/monolog": "^3.0",
        "symfony/console": "^7.0",
        "symfony/yaml": "^7.0",
        "symfony/serializer": "^7.0",
        "symfony/property-access": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.0",
        "phpstan/phpstan": "^1.0",
        "psalm/phar": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "AGUI\\Core\\": "packages/core/src/",
            "AGUI\\Client\\": "packages/client/src/",
            "AGUI\\Proto\\": "packages/proto/src/",
            "AGUI\\Encoder\\": "packages/encoder/src/",
            "AGUI\\CLI\\": "packages/cli/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AGUI\\Tests\\Core\\": "packages/core/tests/",
            "AGUI\\Tests\\Client\\": "packages/client/tests/",
            "AGUI\\Tests\\Proto\\": "packages/proto/tests/",
            "AGUI\\Tests\\Encoder\\": "packages/encoder/tests/",
            "AGUI\\Tests\\CLI\\": "packages/cli/tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "lint": "phpcs --standard=PSR12 src/",
        "lint-fix": "phpcbf --standard=PSR12 src/",
        "analyze": "phpstan analyse src/",
        "psalm": "psalm",
        "build": "composer install --no-dev --optimize-autoloader",
        "clean": "rm -rf vendor/ coverage/"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "authors": [
        {
            "name": "AG-UI Team",
            "email": "team@ag-ui.org"
        }
    ],
    "keywords": [
        "ag-ui",
        "agent-ui",
        "event-driven",
        "protocol",
        "ai",
        "agent"
    ],
    "support": {
        "issues": "https://github.com/ag-ui/ag-ui/issues",
        "source": "https://github.com/ag-ui/ag-ui"
    }
}