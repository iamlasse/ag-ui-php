{
    "name": "ag-ui/laravel-integration",
    "description": "AG-UI integration for Laravel framework",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "laravel/framework": "^10.0|^11.0",
        "ag-ui/core": "*",
        "ag-ui/client": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.0",
        "phpstan/phpstan": "^1.0",
        "psalm/phar": "^5.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "AGUI\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AGUI\\Tests\\Laravel\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "lint": "phpcs --standard=PSR12 src/",
        "lint-fix": "phpcbf --standard=PSR12 src/",
        "analyze": "phpstan analyse src/",
        "psalm": "psalm",
        "build": "composer install --no-dev --optimize-autoloader",
        "clean": "rm -rf vendor/ coverage/"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "AGUI\\Laravel\\AGUIServiceProvider"
            ]
        }
    }
}