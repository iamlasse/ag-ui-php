{
    "name": "ag-ui/symfony",
    "description": "AG-UI integration for Symfony framework",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^7.0",
        "symfony/console": "^7.0",
        "ag-ui/core": "^1.0",
        "ag-ui/client": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/phpunit-bridge": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "AGUI\\Symfony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AGUI\\Tests\\Symfony\\": "tests/"
        }
    }
}