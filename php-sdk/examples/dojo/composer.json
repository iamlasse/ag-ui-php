{
    "name": "ag-ui/dojo-demo",
    "description": "AG-UI Dojo Demo Application",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ag-ui/core": "^1.0",
        "ag-ui/client": "^1.0",
        "ag-ui/cli": "^1.0",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "monolog/monolog": "^3.0",
        "symfony/serializer": "^7.0",
        "symfony/property-access": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "AGUI\\Dojo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AGUI\\Tests\\Dojo\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public/",
        "test": "phpunit",
        "analyze": "phpstan analyse src/"
    }
}