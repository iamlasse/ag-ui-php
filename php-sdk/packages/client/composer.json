{
    "name": "ag-ui/client",
    "description": "AG-UI HTTP client and agent implementations",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ag-ui/core": "^1.0",
        "ag-ui/proto": "^1.0",
        "ag-ui/encoder": "^1.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "guzzlehttp/guzzle": "^7.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "AGUI\\Client\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AGUI\\Tests\\Client\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyse src/"
    }
}