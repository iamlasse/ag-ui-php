{
    "name": "ag-ui/client",
    "description": "AG-UI HTTP client and agent implementations",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ag-ui/core": "*",
        "ag-ui/proto": "*",
        "ag-ui/encoder": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "guzzlehttp/guzzle": "^7.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.0",
        "phpstan/phpstan": "^1.0",
        "psalm/phar": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "AGUI\\Client\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AGUI\\Tests\\Client\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "lint": "phpcs --standard=PSR12 src/",
        "lint-fix": "phpcbf --standard=PSR12 src/",
        "analyze": "phpstan analyse src/",
        "psalm": "psalm",
        "build": "composer install --no-dev --optimize-autoloader",
        "clean": "rm -rf vendor/ coverage/"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}