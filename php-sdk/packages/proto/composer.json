{
    "name": "ag-ui/proto",
    "description": "AG-UI protocol definitions and message types",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "symfony/serializer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "AGUI\\Proto\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AGUI\\Tests\\Proto\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyse src/"
    }
}