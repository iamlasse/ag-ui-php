{
    "name": "ag-ui/cli",
    "description": "AG-UI command-line interface tools",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ag-ui/core": "^1.0",
        "ag-ui/client": "^1.0",
        "ag-ui/encoder": "^1.0",
        "symfony/console": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "AGUI\\CLI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AGUI\\Tests\\CLI\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyse src/"
    }
}