{
    "name": "ag-ui/core",
    "description": "Core AG-UI protocol implementation",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "psr/http-message": "^2.0",
        "symfony/serializer": "^7.0",
        "symfony/property-access": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "AGUI\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AGUI\\Tests\\Core\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyse src/"
    }
}